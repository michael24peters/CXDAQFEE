#uses "FwDevMode.ctl"
CODEXB_SOL40_CODEXB_SOL40_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_SOL40_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_SOL40", devdp);
   fwDU_setDefaultParameters("CODEXB_SOL40", devdp);
   if(dpConnect("cbCODEXB_SOL40_CODEXB_SOL40_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_SOL40_CODEXB_SOL40_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_SOL40 CODEXB_SOL40_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_SOL40_FWDM");
   if(dpDisconnect("cbCODEXB_SOL40_CODEXB_SOL40_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_SOL40_CODEXB_SOL40_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_SOL40_FWDM");
   fwDU_convertValue("CODEXB_SOL40","CODEXB_SOL40_FWDM");
   FwDevMode_valueChanged("CODEXB_SOL40", devdp,
      x1, state );
   fwDU_setState("CODEXB_SOL40", devdp, state);
}

