class: $FWPART_HwTypeGENERICTOPFrontEnd_DU_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_HWTYPEGENERICTOPFRONTEND_DU_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_HWTYPEGENERICTOPFRONTEND_DU_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_HWTYPEGENERICTOPFRONTEND_DU_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_HWTYPEGENERICTOPFRONTEND_DU_FWSETACTIONS
            move_to READY

object: $FWPART_HwTypeGENERICTOPFrontEnd_DU_FWDM is_of_class $FWPART_HwTypeGENERICTOPFrontEnd_DU_FwDevMode_CLASS

