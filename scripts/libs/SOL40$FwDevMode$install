#uses "FwDevMode.ctl"
SOL40_SOL40_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("SOL40_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("SOL40", devdp);
   fwDU_setDefaultParameters("SOL40", devdp);
   if(dpConnect("cbSOL40_SOL40_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

SOL40_SOL40_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling SOL40 SOL40_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("SOL40_FWDM");
   if(dpDisconnect("cbSOL40_SOL40_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbSOL40_SOL40_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("SOL40_FWDM");
   fwDU_convertValue("SOL40","SOL40_FWDM");
   FwDevMode_valueChanged("SOL40", devdp,
      x1, state );
   fwDU_setState("SOL40", devdp, state);
}

