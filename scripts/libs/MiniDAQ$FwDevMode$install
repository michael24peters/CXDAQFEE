#uses "FwDevMode.ctl"
MiniDAQ_MiniDAQ_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("MiniDAQ_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("MiniDAQ", devdp);
   fwDU_setDefaultParameters("MiniDAQ", devdp);
   if(dpConnect("cbMiniDAQ_MiniDAQ_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

MiniDAQ_MiniDAQ_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling MiniDAQ MiniDAQ_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("MiniDAQ_FWDM");
   if(dpDisconnect("cbMiniDAQ_MiniDAQ_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbMiniDAQ_MiniDAQ_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("MiniDAQ_FWDM");
   fwDU_convertValue("MiniDAQ","MiniDAQ_FWDM");
   FwDevMode_valueChanged("MiniDAQ", devdp,
      x1, state );
   fwDU_setState("MiniDAQ", devdp, state);
}

