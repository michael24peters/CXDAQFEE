class: $FWPART_HwTypeGBTQ_SOL40_DU_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_HWTYPEGBTQ_SOL40_DU_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_HWTYPEGBTQ_SOL40_DU_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_HWTYPEGBTQ_SOL40_DU_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_HWTYPEGBTQ_SOL40_DU_FWSETACTIONS
            move_to READY

object: $FWPART_HwTypeGBTQ_SOL40_DU_FWDM is_of_class $FWPART_HwTypeGBTQ_SOL40_DU_FwDevMode_CLASS

